# Pedumo environment variables
# Copy this file to `.env.local` for local development, or configure the same
# names in your deployment provider (Cloudflare Pages, Vercel, etc.).

# Database (optional). If unset, the site still runs; form submissions are
# delivered via LiveForm only and the health endpoint reports db: not-configured.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app_db

# LiveForm form URL for email forwarding. Defaults to the Pedumo form if unset.
LIVEFORM_ENDPOINT=https://liveformhq.com/form/ec51c0e7-70a3-4bbd-97a2-215457068ed3

# Analytics providers (all optional). Scripts load only after the visitor
# consents via the cookie banner.
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_CLARITY_ID=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
